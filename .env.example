# Copie para .env e ajuste os valores. NUNCA versione o .env.

FLASK_CONFIG=development
SECRET_KEY=gere-uma-chave-com-python-secrets-token-hex-32

# Banco de dados. Sem esta variável, o ambiente de desenvolvimento usa
# SQLite em instance/ariadne-dev.db.
# DATABASE_URL=sqlite:////caminho/absoluto/instance/ariadne.db
# DATABASE_URL=postgresql+psycopg://ariadne:senha@localhost:5432/ariadne
# DATABASE_URL=mysql+pymysql://usuario:senha@host/usuario$ariadne?charset=utf8mb4

# Diretório dos arquivos enviados, fora da árvore do código.
# UPLOAD_FOLDER=/home/usuario/ariadne-uploads

# Número de proxies reversos confiáveis à frente da aplicação. Deve ser 0
# quando não há proxy: X-Forwarded-For é forjável pelo cliente e, aceito sem
# proxy, falsearia o IP de origem na trilha de auditoria. Em produção atrás de
# um proxy (PythonAnywhere, Nginx), use 1.
# TRUSTED_PROXY_COUNT=1
